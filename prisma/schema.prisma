generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String?
  avatar    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  meetings  Meeting[]
}


enum MeetingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  description String?
  audioUrl    String?
  status      MeetingStatus @default(PENDING)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}